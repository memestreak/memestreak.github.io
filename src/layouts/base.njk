<!DOCTYPE html>
<html lang='en'>
  <head>
    <title>{{ title }}</title>
    {% include "head.njk" %}
  </head>
  <body>
    <main>
      {{ content | safe }}

      <ul class="visible-links">
          {%- for link in navigation.main -%}
            <li class="masthead__menu-item">
              <a href="{{ link.url }}"{% if link.description %} title="{{ link.description }}"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>

    </main>
  </body>
</html>
